# Frontier assistant supports three providers with auto-detect priority:
#   1. DeepSeek direct  (paid, no daily cap, lowest latency)
#   2. Gemini AI Studio (1,500 free reqs/day per project, no card)
#   3. OpenRouter       (50 free reqs/day per account, no card)
#
# Each provider supports multi-key rotation:
#   - <NAME>S   = comma-separated list of keys (preferred)
#   - <NAME>    = single key (legacy / backward-compat)
# On daily-cap 429, the assistant auto-rotates to the next key in the list.
#
# IMPORTANT: Free-tier daily caps are PER ACCOUNT. Multiple keys from the
# SAME account share one pool. To actually multiply quota, use keys from
# different accounts (sign up with different emails).

# --- DeepSeek direct (paid, no daily cap) -------------------------------------
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_KEYS=key1,key2
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Gemini AI Studio (1,500 free reqs/day) - RECOMMENDED for free demos -----
# Get a key (no credit card): https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_API_KEYS=key1,key2
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- OpenRouter (50 free reqs/day per account) -------------------------------
# Get a key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=
# OPENROUTER_API_KEYS=sk-or-v1-aaa,sk-or-v1-bbb,sk-or-v1-ccc
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Optional overrides --------------------------------------------------------
# OSS_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# FRONTIER_MODEL=gemini-2.0-flash       # or deepseek-chat, or deepseek/deepseek-v4-flash:free
# JUDGE_MODEL=gemini-2.0-flash
