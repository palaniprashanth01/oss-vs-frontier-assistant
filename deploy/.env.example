# The frontier assistant dynamically auto-detects DEEPSEEK_API_KEY or OPENROUTER_API_KEY.
# 1. To use direct official DeepSeek V3 API (low latency, paid):
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# 2. To use free OpenRouter tier (high latency, $0 free):
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: override default OSS model
# OSS_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# Optional: override default frontier model (e.g., deepseek-chat or any OpenRouter slug)
# FRONTIER_MODEL=

# Optional: override LLM judge model used by evaluation
# JUDGE_MODEL=
