# Frontier assistant supports multiple OpenRouter or DeepSeek keys with
# automatic rotation when one hits its daily cap.
#
# Precedence (per category):
#   1. <NAME>S   (comma-separated, multi-key — preferred)
#   2. <NAME>    (single key, legacy / backward-compat)
#
# Precedence (across categories):
#   DeepSeek direct API > OpenRouter free tier
#   (DeepSeek is paid-per-token but has no per-day cap)
#
# IMPORTANT: OpenRouter's 50 free reqs/day cap is PER ACCOUNT, not per-key.
# Multiple keys from the SAME account share the same pool.
# To actually multiply the quota, use keys from different OpenRouter accounts.

# --- DeepSeek direct (paid, no daily cap) -------------------------------------
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_KEYS=key1,key2,key3
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- OpenRouter free tier ($0, 50 free reqs/day per account) ------------------
# OPENROUTER_API_KEY=
# OPENROUTER_API_KEYS=sk-or-v1-aaa,sk-or-v1-bbb,sk-or-v1-ccc
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Optional overrides --------------------------------------------------------
# OSS_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# FRONTIER_MODEL=deepseek/deepseek-v4-flash:free
# JUDGE_MODEL=deepseek/deepseek-v4-flash:free
