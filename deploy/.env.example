# Frontier assistant supports four providers with auto-detect priority:
#   1. DeepSeek direct   (paid, no daily cap, lowest latency)
#   2. Groq Cloud        (free tier + cheap paid, ~500 t/s, GPT-OSS-120B)  — RECOMMENDED
#   3. Gemini AI Studio  (1,500 free reqs/day, can be flaky on new accounts)
#   4. OpenRouter        (50 free reqs/day per account)
#
# Each provider supports multi-key rotation:
#   - <NAME>S   = comma-separated list of keys (preferred)
#   - <NAME>    = single key (legacy / backward-compat)
# On daily-cap 429, the assistant auto-rotates to the next key in the list.

# --- DeepSeek direct (paid, no daily cap) -------------------------------------
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_KEYS=key1,key2
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Groq Cloud (fast + reliable + cheap) - RECOMMENDED ----------------------
# Get a key (no credit card): https://console.groq.com/keys
# Default model: openai/gpt-oss-120b (OpenAI's flagship 120B open-weight)
# GROQ_API_KEY=
# GROQ_API_KEYS=gsk_aaa,gsk_bbb
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Gemini AI Studio (1,500 free reqs/day) ----------------------------------
# Get a key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_API_KEYS=key1,key2
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- OpenRouter (50 free reqs/day per account) -------------------------------
# Get a key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=
# OPENROUTER_API_KEYS=sk-or-v1-aaa,sk-or-v1-bbb
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Optional overrides --------------------------------------------------------
# OSS_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# FRONTIER_MODEL=openai/gpt-oss-120b          # or llama-3.3-70b-versatile, etc.
# JUDGE_MODEL=openai/gpt-oss-120b
